DATABASE_URL=postgresql://user:password@host.neon.tech/lexai?sslmode=require&connection_limit=20
JWT_SECRET=your-random-64-char-secret-here
ANTHROPIC_API_KEY=sk-ant-your-key-here
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GMAIL_REFRESH_TOKEN=your-gmail-refresh-token
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=xxx
RAZORPAY_WEBHOOK_SECRET=xxx
# Legacy one-time payment amount (paise) — used by /payments order route.
# Keep aligned with PRICE_MONTHLY unless you intentionally diverge.
PLATFORM_PRICE=349900
# Razorpay subscription plan IDs — create these in the Razorpay dashboard
# (Subscriptions → Plans) at the amounts below, then paste the IDs here.
RAZORPAY_PLAN_MONTHLY=plan_xxxxxxxxxxxxx
RAZORPAY_PLAN_QUARTERLY=plan_xxxxxxxxxxxxx
RAZORPAY_PLAN_YEARLY=plan_xxxxxxxxxxxxx
# Prices in paise (1 INR = 100 paise). Values are GST-inclusive (18%).
# Monthly  ₹3,499  = 349900 paise
# Quarterly ₹8,999 = 899900 paise
# Yearly   ₹19,999 = 1999900 paise
PRICE_MONTHLY=349900
PRICE_QUARTERLY=899900
PRICE_YEARLY=1999900
EMAIL_FROM=your-email@yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,https://lexailabs.com
BACKEND_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000
PORT=4000
NODE_ENV=development
