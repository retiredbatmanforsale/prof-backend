generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  USER
}

// Per-organization access tier. Distinct from the platform-wide `Role`
// (which governs the global /admin surface). One tier per member — these
// are mutually exclusive, which is why this is a single enum column rather
// than a fan of booleans. STUDENT is the default member; CAMPUS_ADMIN has
// full university visibility (the role the legacy `isOrgAdmin` boolean
// encoded); FACULTY/LAB_ASSISTANT/TA are staff scoped to assigned sections.
enum OrgRole {
  STUDENT
  CAMPUS_ADMIN
  FACULTY
  LAB_ASSISTANT
  TA
}

// Assessment lifecycle. DRAFT is faculty-only (editable, invisible to
// students); PUBLISHED makes it visible to students in the assigned cohorts.
// Evaluation/grading is out of scope for this slice — status never goes
// past PUBLISHED here.
enum AssessmentStatus {
  DRAFT
  PUBLISHED
}

// How an assessment question is sourced. CATALOG references an existing
// practice problem by slug (the catalog lives in the frontend filesystem —
// see prof-frontend/lib/practice/loader.ts); CUSTOM is authored inline and
// stored in `content`. See the assessment domain notes in ASSESSMENT_ENGINE.md.
enum QuestionKind {
  CATALOG
  CUSTOM
}

// Visibility tier — bound to the authoring role:
//   PROF_GLOBAL  — created by Root Admin (platform role=ADMIN); visible to
//                  independent users (no active org membership).
//   ORGANIZATION — created by Campus Admin; visible to ALL students in the org.
//   SECTION      — created by Faculty/TA; visible only to students in the
//                  assigned section(s). This is the default (existing faculty-
//                  authored assessments are section-scoped).
// Student access resolves by persona (see the /assessments route):
//   no org membership      → PROF_GLOBAL
//   student in an org      → ORGANIZATION (their org) + SECTION (their sections)
enum AssessmentVisibility {
  PROF_GLOBAL
  ORGANIZATION
  SECTION
}

// Subject track of an assessment.
enum AssessmentTrack {
  DSA
  AIML
  MIXED
}

// How many times a student may enter an assessment.
enum AttemptPolicy {
  UNLIMITED
  SINGLE
  NONE
}

// In-test navigation between questions.
enum NavigationMode {
  FREE
  SEQUENTIAL
}

// Lifecycle of a single student's attempt at an assessment. Keyed by userId so
// both institutional and independent (PROF_GLOBAL) students are first-class.
enum AttemptStatus {
  IN_PROGRESS
  EXITED
  SUBMITTED
  LOCKED
}

enum PlanType {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum SubscriptionStatus {
  CREATED
  AUTHENTICATED
  ACTIVE
  PENDING
  HALTED
  CANCELLED
  COMPLETED
  EXPIRED
  PAUSED
}

// ─── Core Tables ──────────────────────────────────────────────

model User {
  id                  String    @id @default(cuid())
  name                String
  email               String    @unique
  emailVerified       DateTime?
  phone               String?
  razorpayCustomerId  String?   @unique
  image               String?
  hashedPassword      String?
  role           Role      @default(USER)
  isActive       Boolean   @default(true)
  isPremium      Boolean   @default(false)
  // Admin-granted comp expiry. Null means "no comp" or "lifetime comp"
  // (the two cases are distinguished by isPremium + the absence of a
  // Subscription / legacy Payment row). When set and in the past,
  // getAccessInfo auto-revokes isPremium on the next refresh.
  premiumEndsAt  DateTime?
  premiumGrantReason String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  oauthAccounts           OAuthAccount[]
  refreshTokens           RefreshToken[]
  organizationMembers     OrganizationMember[]
  payments                Payment[]
  subscriptions           Subscription[]
  passwordResetTokens     PasswordResetToken[]
  claimedPreloadedRecords PreloadedStudent[] @relation("ClaimedBy")
  quizAttempts            QuizAttempt[]
  lessonProgress          LessonProgress[]
  practiceAttempts        PracticeAttempt[]
  gradeEntries            GradeEntry[]
  lessonLikes             LessonLike[]
  streak                  UserStreak?
  assessmentAttempts      AssessmentAttempt[]

  @@map("users")
}

model OAuthAccount {
  id                String @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("oauth_accounts")
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  isRevoked Boolean   @default(false)
  rotatedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ─── Institutional Tables ─────────────────────────────────────

model Organization {
  id              String    @id @default(cuid())
  name            String
  slug            String    @unique
  emailDomains    String[]
  isActive        Boolean   @default(true)
  accessStartDate DateTime?
  accessEndDate   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  members           OrganizationMember[]
  preloadedStudents PreloadedStudent[]
  sections          Section[]
  assessments       Assessment[]

  @@map("organizations")
}

model OrganizationMember {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  isVerified     Boolean  @default(false)
  isActive       Boolean  @default(true)
  // When true, this member can view their organization's consolidated
  // metrics dashboard (/org/*). Distinct from the global Role.ADMIN, which
  // governs the platform-wide /admin surface. Toggled by a platform admin.
  // DEPRECATED in favor of `orgRole` (CAMPUS_ADMIN). Kept during the
  // transition so existing read sites keep working; backfilled from it and
  // dropped once all callers read `orgRole`.
  isOrgAdmin     Boolean  @default(false)
  // Per-org access tier — see OrgRole. CAMPUS_ADMIN == legacy isOrgAdmin.
  orgRole        OrgRole  @default(STUDENT)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  expiryNotices    ExpiryNoticeLog[]
  // Cohort membership (as a learner) and teaching assignments (as staff).
  sectionStudentOf   SectionStudent[]
  sectionAssignments SectionAssignment[]
  // Assessments this member authored (as faculty).
  assessmentsAuthored Assessment[] @relation("AssessmentAuthor")
  // Grade entries this member recorded (Phase 5 gradebook).
  enteredGradeEntries GradeEntry[] @relation("GradeEntryEnteredBy")

  @@unique([userId, organizationId])
  @@map("organization_members")
}

// ─── Sections (cohorts) ───────────────────────────────────────
// A Section is a sub-group of an organization's members — the "cohort" the
// university dashboard hierarchy operates on. Campus admins manage all
// sections in their org; faculty/TA staff are assigned to specific sections
// (SectionAssignment) and see only those. See SECTION_MODEL_PLAN.md.

model Section {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  course         String?
  createdViaCsv  Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization      Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  students          SectionStudent[]
  staff             SectionAssignment[]
  preloadedStudents PreloadedStudent[]
  assessments       Assessment[] // assessments owned directly by this cohort (Phase 2)
  gradeComponents   GradeComponent[] // Phase 5: gradebook components for this cohort

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("sections")
}

// Student membership in a section. Many-to-many (a student may sit in more
// than one cohort). Keyed off OrganizationMember so section metrics reuse the
// org member → userId resolution.
model SectionStudent {
  id                   String @id @default(cuid())
  sectionId            String
  organizationMemberId String

  section Section            @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  member  OrganizationMember @relation(fields: [organizationMemberId], references: [id], onDelete: Cascade)

  @@unique([sectionId, organizationMemberId])
  // ONE-COHORT hard guarantee (Phase D): a member belongs to exactly one org, so
  // a global unique on organizationMemberId enforces "one student = one cohort"
  // at the DB level — the backstop the app-only check lacks against TOCTOU
  // races. Supersedes the former plain @@index.
  @@unique([organizationMemberId])
  @@map("section_students")
}

// Teaching-staff assignment to a section — this is what scopes the faculty
// (L2) view: a faculty member sees only the sections they're assigned to.
model SectionAssignment {
  id                   String   @id @default(cuid())
  sectionId            String
  organizationMemberId String
  assignedAt           DateTime @default(now())
  assignedByUserId     String?

  section Section            @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  member  OrganizationMember @relation(fields: [organizationMemberId], references: [id], onDelete: Cascade)

  @@unique([sectionId, organizationMemberId])
  @@index([organizationMemberId])
  @@map("section_assignments")
}

// ─── Assessments ──────────────────────────────────────────────
// An Assessment is authored by a faculty OrganizationMember and assigned to
// one or more Sections (cohorts) the author teaches. Students in those
// cohorts see it once it is PUBLISHED. Evaluation, scoring, plagiarism and
// code execution are intentionally out of scope for this slice — questions
// are stored but never run or graded. See ASSESSMENT_ENGINE.md.

model Assessment {
  id                String           @id @default(cuid())
  organizationId    String
  // The faculty OrganizationMember who authored this. Tying to the member
  // (not the User) keeps authorship inside the org boundary, mirroring how
  // sections are keyed.
  createdByMemberId String
  // The single cohort that owns this assessment (Phase 2). The legacy
  // AssessmentAssignment bridge was dropped in Phase 8.
  sectionId         String?
  title             String
  description       String?
  status            AssessmentStatus @default(DRAFT)
  // PROF_GLOBAL / ORGANIZATION / SECTION — drives which student persona can see
  // it and which role authored it. Defaults to SECTION (faculty-authored).
  visibility        AssessmentVisibility @default(SECTION)
  // Authoring metadata + in-test rules (all additive, sensible defaults so
  // existing rows are unaffected).
  track             AssessmentTrack  @default(MIXED)
  attemptPolicy     AttemptPolicy    @default(UNLIMITED)
  lateEntryAllowed  Boolean          @default(true)
  shuffleQuestions  Boolean          @default(false)
  navigationMode    NavigationMode   @default(FREE)
  autoSubmit        Boolean          @default(true)
  // Optional scheduling metadata surfaced to students; not enforced server-
  // side in this slice (no timed-attempt engine yet).
  durationMinutes   Int?
  opensAt           DateTime?
  dueAt             DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  organization Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    OrganizationMember     @relation("AssessmentAuthor", fields: [createdByMemberId], references: [id])
  section      Section?               @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  questions    AssessmentQuestion[]
  attempts     AssessmentAttempt[]
  gradeComponents GradeComponent[] // Phase 5: AUTO grade components sourced from this assessment

  @@index([organizationId])
  @@index([createdByMemberId])
  @@index([sectionId])
  @@map("assessments")
}

// ─── Phase 5: Gradebook ───────────────────────────────────────
// The final academic grading layer. A GradeComponent is one weighted column of
// a cohort's gradebook (e.g. "Mid-Sem" 30%, "Viva" 10%). A GradeEntry is one
// student's score in one component. Scores flow in two ways:
//   AUTO   — pulled from a linked assessment's attempts once assessment grading
//            exists (assessmentId set). Forward-compatible: the grading engine
//            isn't built yet, so AUTO components are entered manually for now.
//   MANUAL — faculty types the score (viva / project / lab exams / internals).
// Total % and letter grade are DERIVED on read (lib/university/gradebook.ts),
// never stored — single source of truth shared by faculty + student views.

enum GradeComponentType {
  MIDSEM
  ENDSEM
  QUIZ
  VIVA
  PROJECT
  LAB
}

enum GradeSource {
  AUTO
  MANUAL
}

model GradeComponent {
  id        String             @id @default(cuid())
  sectionId String
  name      String
  type      GradeComponentType
  maxMarks  Float              @default(100)
  weight    Float              @default(0)
  // Optional: AUTO components source their scores from this assessment's
  // attempts. Null = a purely manual component (viva, project, lab exam…).
  assessmentId String?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  section    Section      @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  assessment Assessment?  @relation(fields: [assessmentId], references: [id], onDelete: SetNull)
  entries    GradeEntry[]

  @@index([sectionId])
  @@map("grade_components")
}

model GradeEntry {
  id                String      @id @default(cuid())
  componentId       String
  studentId         String // User.id of the graded student
  score             Float
  // OrganizationMember who recorded it (faculty/admin). Null for AUTO entries.
  enteredByMemberId String?
  source            GradeSource @default(MANUAL)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  component GradeComponent      @relation(fields: [componentId], references: [id], onDelete: Cascade)
  student   User                @relation(fields: [studentId], references: [id], onDelete: Cascade)
  enteredBy OrganizationMember? @relation("GradeEntryEnteredBy", fields: [enteredByMemberId], references: [id], onDelete: SetNull)

  @@unique([componentId, studentId])
  @@index([studentId])
  @@map("grade_entries")
}

// One student's attempt at an assessment. Keyed by `userId` (NOT
// OrganizationMember) so independent PROF_GLOBAL students — who have no org
// membership — are first-class. `answers` holds the in-progress/submitted
// response map; `remainingAttempts` + `status` drive the attempt-policy gate.
model AssessmentAttempt {
  id                String        @id @default(cuid())
  assessmentId      String
  userId            String
  startedAt         DateTime      @default(now())
  exitedAt          DateTime?
  remainingAttempts Int           @default(1)
  status            AttemptStatus @default(IN_PROGRESS)
  answers           Json?
  // ─── Phase 6: scoring (additive) ───
  // score is the final awarded total (auto + any faculty review marks); it is
  // provisional while pendingReview is true (auto portion only) and final once
  // gradedAt is set. maxScore is the sum of all question points. reviewMarks
  // holds faculty-assigned marks for non-auto questions ({ questionId: marks }).
  score         Float?
  maxScore      Float?
  submittedAt   DateTime?
  gradedAt      DateTime?
  pendingReview Boolean   @default(false)
  reviewMarks   Json?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, userId])
  @@index([userId])
  @@map("assessment_attempts")
}

// One question within an assessment, ordered by `order` (0-based). A question
// is either a CATALOG reference (catalogSlug into the frontend practice
// catalog) or a CUSTOM question authored inline (body in `content`). The
// backend never reaches into the catalog files — for CATALOG questions the
// frontend supplies a lightweight snapshot (title/difficulty/topics) stored in
// `content` so lists render server-side without the catalog.
model AssessmentQuestion {
  id           String       @id @default(cuid())
  assessmentId String
  order        Int
  kind         QuestionKind
  points       Int?
  // CATALOG only: slug of the referenced practice problem.
  catalogSlug  String?
  // Display label / snapshot title (both kinds).
  title        String?
  // CUSTOM: the full question body ({ type, prompt, options, ... } — see
  // src/schemas/assessment.ts). CATALOG: a small snapshot ({ difficulty,
  // topics, ... }). Answer keys live here and are stripped from the
  // student-facing serializer.
  content      Json?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
  @@map("assessment_questions")
}

// Phase 8: the AssessmentAssignment join table was removed. An assessment is
// owned by exactly one cohort via Assessment.sectionId; students resolve
// visibility by their section (or ORGANIZATION / PROF_GLOBAL scope).

// One row per (member, kind, targetEndDate) so a heads-up is sent at most
// once per upcoming expiry. If an admin extends accessEndDate, the new date
// is a new targetEndDate and the warning re-fires.
model ExpiryNoticeLog {
  id                   String   @id @default(cuid())
  organizationMemberId String
  kind                 String
  targetEndDate        DateTime
  sentAt               DateTime @default(now())

  organizationMember OrganizationMember @relation(fields: [organizationMemberId], references: [id], onDelete: Cascade)

  @@unique([organizationMemberId, kind, targetEndDate])
  @@index([organizationMemberId])
  @@map("expiry_notice_logs")
}

model PreloadedStudent {
  id              String   @id @default(cuid())
  email           String
  name            String?
  organizationId  String
  claimed         Boolean  @default(false)
  claimedByUserId String?
  // Carries the org-admin designation set via the admins CSV upload (or the
  // single add) before the person has an account. When they claim their
  // invite (or auto-claim on login), this seeds OrganizationMember.isOrgAdmin
  // so the org metrics dashboard (/org/*) becomes available to them.
  // DEPRECATED in favor of `orgRole` (CAMPUS_ADMIN); see OrganizationMember.
  isOrgAdmin      Boolean  @default(false)
  // Per-org tier set at upload time (campus-admin CSV → CAMPUS_ADMIN,
  // faculty CSV → FACULTY/LAB_ASSISTANT/TA). Seeds OrganizationMember.orgRole
  // when the invite is claimed.
  orgRole         OrgRole  @default(STUDENT)
  // Intended section (cohort), set when a roster CSV preloads this student
  // before they have an account. On claim, the claim flow creates the
  // SectionStudent link from this. Null for non-cohorted students.
  sectionId       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  claimedBy        User?             @relation("ClaimedBy", fields: [claimedByUserId], references: [id])
  section          Section?          @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  invitationTokens InvitationToken[]

  @@unique([organizationId, email])
  @@map("preloaded_students")
}

model InvitationToken {
  id                 String   @id @default(cuid())
  token              String   @unique
  preloadedStudentId String
  expiresAt          DateTime
  used               Boolean  @default(false)
  createdAt          DateTime @default(now())

  preloadedStudent PreloadedStudent @relation(fields: [preloadedStudentId], references: [id], onDelete: Cascade)

  @@map("invitation_tokens")
}

// ─── Payment Tables ──────────────────────────────────────────

model Payment {
  id                String   @id @default(cuid())
  userId            String
  razorpayOrderId   String   @unique
  razorpayPaymentId String?  @unique
  amount            Int
  currency          String   @default("INR")
  status            String   @default("created")
  receipt           String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("payments")
}

// ─── Subscription Tables ─────────────────────────────────────

model Subscription {
  id                     String             @id @default(cuid())
  userId                 String
  razorpaySubscriptionId String             @unique
  razorpayPlanId         String
  planType               PlanType
  status                 SubscriptionStatus @default(CREATED)
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  cancelledAt            DateTime?
  endedAt                DateTime?
  shortUrl               String?
  // First captured payment on this subscription — the only payment eligible
  // for the 7-day refund window.
  firstPaymentId         String?
  firstPaymentAt         DateTime?
  // Refund tracking. One refund per subscription (v1).
  refundId               String?
  refundedAt             DateTime?
  refundStatus           String?
  refundAmount           Int?
  // Plan-switch state. Set when the user requests a Monthly→Yearly (or
  // any plan-to-plan) change via /subscriptions/switch-plan; cleared
  // when the next subscription.charged webhook reflects the new plan.
  // Razorpay applies the switch at cycle end so continuity is preserved.
  pendingPlanType        PlanType?
  pendingPlanChangeAt    DateTime?
  // Dunning idempotency. We email the user once per failed-charge cycle.
  // Set to the currentPeriodEnd that failed; if it matches on a re-fired
  // pending webhook, we skip. Cleared on successful subscription.charged.
  dunningSentForPeriodEnd DateTime?
  // Receipt idempotency. Set to the Razorpay payment_id we last
  // emailed a receipt for; webhook replays for the same payment skip.
  lastReceiptPaymentId   String?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("subscriptions")
}

// ─── Progress Tables ─────────────────────────────────────────

enum ProgressStatus {
  IN_PROGRESS
  READ
  MASTERED
}

model LessonProgress {
  id         String         @id @default(cuid())
  userId     String
  lessonId   String
  status     ProgressStatus @default(IN_PROGRESS)
  readAt     DateTime?
  masteredAt DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  // ─── Phase 3: robust lesson tracking (additive) ───
  // A lesson is "completed" only when the student explicitly completes it AND
  // met the meaningful-engagement gate (min time + min scroll) — opening a
  // lesson is never enough. completedAt is the authoritative completion marker
  // (status flips to READ at the same time). completionPercent is the deepest
  // scroll depth reached (0–100). timeSpentSeconds accumulates from heartbeats.
  startedAt         DateTime?
  completedAt       DateTime?
  timeSpentSeconds  Int       @default(0)
  completionPercent Int       @default(0)
  lastActiveAt      DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
  @@map("lesson_progress")
}

// Phase 3: thin per-(user, problem) practice tracking. Coding labs run in the
// browser; the solver POSTs here on run (attempt) and on all-tests-pass (solve).
// problemSlug matches the practice catalog slug / lessonPracticeMap ids, so
// faculty + the roadmap can join solved labs back to lessons. Deliberately
// minimal — no submissions/history, just the attempt count and solved flag.
model PracticeAttempt {
  id          String    @id @default(cuid())
  userId      String
  problemSlug String
  attempts    Int       @default(0)
  solved      Boolean   @default(false)
  solvedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, problemSlug])
  @@index([userId])
  @@index([problemSlug])
  @@map("practice_attempts")
}

// One row per (user, lessonSlug) — a like is a binary signal. Unique
// constraint at the DB layer enforces one-vote-per-user-per-lesson, so
// the frontend can be naive about double-clicks without server-side
// dedup logic. Slug is the canonical lesson identifier — see the
// slug-churn policy in /Users/lexai/Documents/prof/LIKES_FEATURE_PLAN.md
// (commit to stable slugs; rename = manual UPDATE migration).
model LessonLike {
  id         String   @id @default(cuid())
  userId     String
  lessonSlug String
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonSlug])
  @@index([lessonSlug])
  @@map("lesson_likes")
}

// ─── Quiz Tables ─────────────────────────────────────────────

model QuizAttempt {
  id        String   @id @default(cuid())
  userId    String
  lessonId  String
  score     Int
  total     Int
  answers   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@map("quiz_attempts")
}

// Per-user streak state. One row per user, keyed by userId so the row
// is created lazily on first activity and trivially looked up on every
// page mount. Days are computed in UTC server-side (intentional — see
// STREAK_BACKEND_PLAN.md in prof-frontend for the timezone tradeoff).
// `todayActivities` is pruned on the first event of a new UTC day.
// `history` keeps a compact {YYYY-MM-DD: true} map for the 30-day
// heatmap on /account; older data can be reconstructed from
// LessonProgress + QuizAttempt timestamps if a wider range is needed.
model UserStreak {
  userId           String    @id
  currentStreak    Int       @default(0)
  longestStreak    Int       @default(0)
  totalActiveDays  Int       @default(0)
  freezesAvailable Int       @default(3)
  lastActiveDay    DateTime? @db.Date
  todayActivities  Json      @default("[]")
  history          Json      @default("{}")
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_streak")
}

// ─── Waitlist ─────────────────────────────────────────────────

// Pre-launch lead capture from any surface that asks for an email —
// /experiences, the Memorandum PDF gate on /subscribe, the standalone
// waitlist.lexailabs.com landing, etc. One row per email; the source
// + metadata fields let us segment by acquisition channel and campaign.
model WaitlistEntry {
  id             String    @id @default(cuid())
  email          String    @unique
  source         String

  // Optional self-reported fields. Most surfaces only collect email; the
  // dedicated waitlist landing will capture name/role/org via a fuller
  // form. Schema accommodates both without forcing any one form to ask.
  name           String?
  phone          String?
  organization   String?
  role           String?

  // Auto-captured attribution. Lets us tell apart organic LinkedIn
  // traffic from a paid Reddit drop without changing the form.
  referrer       String?
  utmSource      String?
  utmMedium      String?
  utmCampaign    String?
  ipAddress      String?
  userAgent      String?
  metadata       Json?

  // Conversion funnel tracking — set when the waitlist member finally
  // signs up (and again if they subscribe). Lets us measure the full
  // signup → paid path back to the original waitlist source.
  notified       Boolean   @default(false)
  notifiedAt     DateTime?
  convertedUserId String?
  convertedAt    DateTime?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  // Bumps on every re-submission of the same email so we can prioritise
  // re-engaged visitors when we send the launch email.
  lastSeenAt     DateTime  @default(now())

  @@index([source])
  @@index([createdAt])
  @@map("waitlist_entries")
}

// ─── Admin Audit Log ──────────────────────────────────────────

// Append-only record of admin actions on institutional/membership state.
// Captures who did what, when, and any relevant before/after values so
// access changes can be reconstructed without trawling DB backups.
model AdminAuditLog {
  id         String   @id @default(cuid())
  actorId    String
  actorEmail String
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("admin_audit_logs")
}

// ─── Auth Support Tables ──────────────────────────────────────

model EmailVerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}
