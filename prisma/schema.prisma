generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  USER
}

enum PlanType {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum SubscriptionStatus {
  CREATED
  AUTHENTICATED
  ACTIVE
  PENDING
  HALTED
  CANCELLED
  COMPLETED
  EXPIRED
  PAUSED
}

// ─── Core Tables ──────────────────────────────────────────────

model User {
  id                  String    @id @default(cuid())
  name                String
  email               String    @unique
  emailVerified       DateTime?
  phone               String?
  razorpayCustomerId  String?   @unique
  image               String?
  hashedPassword      String?
  role           Role      @default(USER)
  isActive       Boolean   @default(true)
  isPremium      Boolean   @default(false)
  // Admin-granted comp expiry. Null means "no comp" or "lifetime comp"
  // (the two cases are distinguished by isPremium + the absence of a
  // Subscription / legacy Payment row). When set and in the past,
  // getAccessInfo auto-revokes isPremium on the next refresh.
  premiumEndsAt  DateTime?
  premiumGrantReason String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  oauthAccounts           OAuthAccount[]
  refreshTokens           RefreshToken[]
  organizationMembers     OrganizationMember[]
  payments                Payment[]
  subscriptions           Subscription[]
  passwordResetTokens     PasswordResetToken[]
  claimedPreloadedRecords PreloadedStudent[] @relation("ClaimedBy")
  quizAttempts            QuizAttempt[]
  lessonProgress          LessonProgress[]

  @@map("users")
}

model OAuthAccount {
  id                String @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("oauth_accounts")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ─── Institutional Tables ─────────────────────────────────────

model Organization {
  id              String    @id @default(cuid())
  name            String
  slug            String    @unique
  emailDomains    String[]
  isActive        Boolean   @default(true)
  accessStartDate DateTime?
  accessEndDate   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  members           OrganizationMember[]
  preloadedStudents PreloadedStudent[]

  @@map("organizations")
}

model OrganizationMember {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  isVerified     Boolean  @default(false)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  expiryNotices    ExpiryNoticeLog[]

  @@unique([userId, organizationId])
  @@map("organization_members")
}

// One row per (member, kind, targetEndDate) so a heads-up is sent at most
// once per upcoming expiry. If an admin extends accessEndDate, the new date
// is a new targetEndDate and the warning re-fires.
model ExpiryNoticeLog {
  id                   String   @id @default(cuid())
  organizationMemberId String
  kind                 String
  targetEndDate        DateTime
  sentAt               DateTime @default(now())

  organizationMember OrganizationMember @relation(fields: [organizationMemberId], references: [id], onDelete: Cascade)

  @@unique([organizationMemberId, kind, targetEndDate])
  @@index([organizationMemberId])
  @@map("expiry_notice_logs")
}

model PreloadedStudent {
  id              String   @id @default(cuid())
  email           String
  name            String?
  organizationId  String
  claimed         Boolean  @default(false)
  claimedByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  claimedBy        User?             @relation("ClaimedBy", fields: [claimedByUserId], references: [id])
  invitationTokens InvitationToken[]

  @@unique([organizationId, email])
  @@map("preloaded_students")
}

model InvitationToken {
  id                 String   @id @default(cuid())
  token              String   @unique
  preloadedStudentId String
  expiresAt          DateTime
  used               Boolean  @default(false)
  createdAt          DateTime @default(now())

  preloadedStudent PreloadedStudent @relation(fields: [preloadedStudentId], references: [id], onDelete: Cascade)

  @@map("invitation_tokens")
}

// ─── Payment Tables ──────────────────────────────────────────

model Payment {
  id                String   @id @default(cuid())
  userId            String
  razorpayOrderId   String   @unique
  razorpayPaymentId String?  @unique
  amount            Int
  currency          String   @default("INR")
  status            String   @default("created")
  receipt           String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("payments")
}

// ─── Subscription Tables ─────────────────────────────────────

model Subscription {
  id                     String             @id @default(cuid())
  userId                 String
  razorpaySubscriptionId String             @unique
  razorpayPlanId         String
  planType               PlanType
  status                 SubscriptionStatus @default(CREATED)
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  cancelledAt            DateTime?
  endedAt                DateTime?
  shortUrl               String?
  // First captured payment on this subscription — the only payment eligible
  // for the 7-day refund window.
  firstPaymentId         String?
  firstPaymentAt         DateTime?
  // Refund tracking. One refund per subscription (v1).
  refundId               String?
  refundedAt             DateTime?
  refundStatus           String?
  refundAmount           Int?
  // Plan-switch state. Set when the user requests a Monthly→Yearly (or
  // any plan-to-plan) change via /subscriptions/switch-plan; cleared
  // when the next subscription.charged webhook reflects the new plan.
  // Razorpay applies the switch at cycle end so continuity is preserved.
  pendingPlanType        PlanType?
  pendingPlanChangeAt    DateTime?
  // Dunning idempotency. We email the user once per failed-charge cycle.
  // Set to the currentPeriodEnd that failed; if it matches on a re-fired
  // pending webhook, we skip. Cleared on successful subscription.charged.
  dunningSentForPeriodEnd DateTime?
  // Receipt idempotency. Set to the Razorpay payment_id we last
  // emailed a receipt for; webhook replays for the same payment skip.
  lastReceiptPaymentId   String?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("subscriptions")
}

// ─── Progress Tables ─────────────────────────────────────────

enum ProgressStatus {
  IN_PROGRESS
  READ
  MASTERED
}

model LessonProgress {
  id         String         @id @default(cuid())
  userId     String
  lessonId   String
  status     ProgressStatus @default(IN_PROGRESS)
  readAt     DateTime?
  masteredAt DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
  @@map("lesson_progress")
}

// ─── Quiz Tables ─────────────────────────────────────────────

model QuizAttempt {
  id        String   @id @default(cuid())
  userId    String
  lessonId  String
  score     Int
  total     Int
  answers   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@map("quiz_attempts")
}

// ─── Waitlist ─────────────────────────────────────────────────

// Pre-launch lead capture from any surface that asks for an email —
// /experiences, the Memorandum PDF gate on /subscribe, the standalone
// waitlist.lexailabs.com landing, etc. One row per email; the source
// + metadata fields let us segment by acquisition channel and campaign.
model WaitlistEntry {
  id             String    @id @default(cuid())
  email          String    @unique
  source         String

  // Optional self-reported fields. Most surfaces only collect email; the
  // dedicated waitlist landing will capture name/role/org via a fuller
  // form. Schema accommodates both without forcing any one form to ask.
  name           String?
  phone          String?
  organization   String?
  role           String?

  // Auto-captured attribution. Lets us tell apart organic LinkedIn
  // traffic from a paid Reddit drop without changing the form.
  referrer       String?
  utmSource      String?
  utmMedium      String?
  utmCampaign    String?
  ipAddress      String?
  userAgent      String?
  metadata       Json?

  // Conversion funnel tracking — set when the waitlist member finally
  // signs up (and again if they subscribe). Lets us measure the full
  // signup → paid path back to the original waitlist source.
  notified       Boolean   @default(false)
  notifiedAt     DateTime?
  convertedUserId String?
  convertedAt    DateTime?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  // Bumps on every re-submission of the same email so we can prioritise
  // re-engaged visitors when we send the launch email.
  lastSeenAt     DateTime  @default(now())

  @@index([source])
  @@index([createdAt])
  @@map("waitlist_entries")
}

// ─── Admin Audit Log ──────────────────────────────────────────

// Append-only record of admin actions on institutional/membership state.
// Captures who did what, when, and any relevant before/after values so
// access changes can be reconstructed without trawling DB backups.
model AdminAuditLog {
  id         String   @id @default(cuid())
  actorId    String
  actorEmail String
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("admin_audit_logs")
}

// ─── Auth Support Tables ──────────────────────────────────────

model EmailVerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}
